<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="UsingCTemplate" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/UsingCTemplate" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
					<Add directory="sdl/include" />
				</Compiler>
				<Linker>
					<Add library="mingw32" />
					<Add library="SDL2main" />
					<Add library="SDL2" />
					<Add library="SDL2_image" />
					<Add library="SDL2_ttf" />
					<Add library="SDL2_mixer" />
					<Add library="user32" />
					<Add library="gdi32" />
					<Add library="winmm" />
					<Add library="imm32" />
					<Add library="ole32" />
					<Add library="oleaut32" />
					<Add library="version" />
					<Add library="uuid" />
					<Add directory="sdl/lib" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/UsingCTemplate" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add library="mingw32" />
					<Add library="SDL2main" />
					<Add library="SDL2" />
					<Add library="SDL2_image" />
					<Add library="SDL2_ttf" />
					<Add library="SDL2_mixer" />
					<Add library="user32" />
					<Add library="gdi32" />
					<Add library="winmm" />
					<Add library="imm32" />
					<Add library="ole32" />
					<Add library="oleaut32" />
					<Add library="version" />
					<Add library="uuid" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
		</Compiler>
		<Linker>
			<Add library="mingw32" />
			<Add library="SDL2main" />
			<Add library="SDL2" />
			<Add library="SDL2_image" />
			<Add library="SDL2_ttf" />
			<Add library="SDL2_mixer" />
			<Add library="user32" />
			<Add library="gdi32" />
			<Add library="winmm" />
			<Add library="imm32" />
			<Add library="ole32" />
			<Add library="oleaut32" />
			<Add library="version" />
			<Add library="uuid" />
		</Linker>
		<Unit filename="src/common.h" />
		<Unit filename="src/defs.h" />
		<Unit filename="src/draw.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="src/draw.h" />
		<Unit filename="src/init.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="src/init.h" />
		<Unit filename="src/input.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="src/input.h" />
		<Unit filename="src/main.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="src/main.h" />
		<Unit filename="src/structs.h" />
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
